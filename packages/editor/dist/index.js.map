      "example": "print rand_look(0.5)",
      "kind": "function",
      "category": "core",
      "sourceUrl": "https://sonic-pi.net/tutorial.html"
    },
    "rand_i_look": {
      "signature": "rand_i_look(max: number_or_range)",
